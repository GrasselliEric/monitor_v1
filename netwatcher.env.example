# Arquivo de variáveis de ambiente para o NetWatcher.
# Instalar em /etc/netwatcher/netwatcher.env com permissão restrita:
#   sudo install -d -m 0750 -o root -g netwatcher /etc/netwatcher
#   sudo install -m 0640 -o root -g netwatcher netwatcher.env.example /etc/netwatcher/netwatcher.env
#   sudo vi /etc/netwatcher/netwatcher.env  # preencher o webhook real
#
# IMPORTANTE: NÃO commitar este arquivo preenchido. Use somente como template.

NETWATCHER_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=YOUR_KEY&token=YOUR_TOKEN
